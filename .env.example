# Скопируйте в .env и заполните значения

# Telegram
BOT_TOKEN=your_bot_token_from_botfather
GROUP_ID=-1001234567890

# Таймауты (минуты)
REMIND_AFTER_MIN=15
ESCALATE_AFTER_MIN=30

# Расписание (часы, минуты)
MILK_HOUR=13
MILK_MIN=0
BAKERY_HOUR=20
BAKERY_MIN=0
FREEZER_HOUR=20
FREEZER_MIN=5
OPENING_HOUR=7
OPENING_MIN=0
CASH_HOUR=20
CASH_MIN=0
CLOSING_HOUR=21
CLOSING_MIN=0

# Регламент: санитария и оборудование (false — не ставить в cron)
SANITARY_ENABLED=true
SANITARY_HOUR=14
SANITARY_MIN=0
EQUIPMENT_ENABLED=true
EQUIPMENT_HOUR=12
EQUIPMENT_MIN=0

# ИИ (ответы /ask по файлу FAQ)
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# FAQ_PATH=/absolute/path/to/custom_faq.md

# Памятка 2 раза в день (9:00 и 15:00)
MEMO_HOUR_1=9
MEMO_MIN_1=0
MEMO_HOUR_2=15
MEMO_MIN_2=0

# API
API_HOST=0.0.0.0
API_PORT=8080
RUN_API=true
